<div class="page-header animate-in">
  <h1>Premium Catalog</h1>
  <p>Explore our exclusive collection of premium streetwear and accessories.</p>
</div>

<div class="filter-bar glass-card animate-in" style="animation-delay: 0.05s;">
  <div class="search-wrapper">
    <span class="search-icon">🔍</span>
    <input type="text" id="searchInput" class="form-control" placeholder="Search products..." oninput="handleSearch()">
  </div>

  <select id="categoryFilter" class="form-control" onchange="loadProducts()">
    <option value="">All Categories</option>
  </select>

  <select id="priceSort" class="form-control" onchange="loadProducts()">
    <option value="">Sort By</option>
    <option value="price-asc">Price: Low to High</option>
    <option value="price-desc">Price: High to Low</option>
    <option value="name-asc">Name: A to Z</option>
  </select>
</div>

<div id="productGrid" class="product-grid animate-in" style="animation-delay: 0.1s; margin-top: 32px;">
  <div class="spinner"></div>
</div>

<script>
  let categories = [];
  let products = [];
  let searchTimeout = null;

  const PLACEHOLDER_IMG = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23f1f5f9"/><text x="50" y="55" font-family="sans-serif" font-size="12" fill="%2394a3b8" text-anchor="middle">No Image</text></svg>';

  document.addEventListener('DOMContentLoaded', async () => {
    await loadCategories();
    await loadProducts();
  });

  async function loadCategories() {
    try {
      const data = await api('/products/categories');
      categories = data;
      const select = document.getElementById('categoryFilter');
      data.forEach(cat => {
        const option = document.createElement('option');
        option.value = cat.id;
        option.textContent = cat.name;
        select.appendChild(option);
      });
    } catch (err) {
      showToast('Failed to load categories', 'error');
    }
  }

  function handleSearch() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      loadProducts();
    }, 400);
  }

  document.getElementById('searchInput').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      clearTimeout(searchTimeout);
      loadProducts();
    }
  });

  async function loadProducts() {
    const grid = document.getElementById('productGrid');
    grid.innerHTML = '<div class="spinner"></div>';

    const search = document.getElementById('searchInput').value;
    const categoryId = document.getElementById('categoryFilter').value;
    const sort = document.getElementById('priceSort').value;

    let queryParams = [];
    if (search) queryParams.push(`search=${encodeURIComponent(search)}`);
    if (categoryId) queryParams.push(`category_id=${categoryId}`);
    queryParams.push('limit=100');

    const queryString = queryParams.length ? '?' + queryParams.join('&') : '';

    try {
      const response = await api(`/products${queryString}`);
      products = response.products || [];

      if (sort === 'price-asc') {
        products.sort((a, b) => parseFloat(a.min_price) - parseFloat(b.min_price));
      } else if (sort === 'price-desc') {
        products.sort((a, b) => parseFloat(b.min_price) - parseFloat(a.min_price));
      } else if (sort === 'name-asc') {
        products.sort((a, b) => a.name.localeCompare(b.name));
      }

      renderProducts();
    } catch (err) {
      grid.innerHTML = '<div class="empty-state"><span class="empty-icon">⚠️</span><h3>Error loading products</h3><p>' + escapeHtml(err.message) + '</p></div>';
    }
  }

  function renderProducts() {
    const grid = document.getElementById('productGrid');
    if (products.length === 0) {
      grid.innerHTML = `
        <div class="empty-state" style="grid-column: 1 / -1;">
          <span class="empty-icon">🛍️</span>
          <h3>No products found</h3>
          <p>Try resetting your search or category filters.</p>
        </div>
      `;
      return;
    }

    grid.innerHTML = products.map(prod => {
      const isLowStock = prod.total_stock > 0 && prod.total_stock <= 10;
      const isOutOfStock = prod.total_stock == 0;
      let stockHtml = `<span class="product-stock stock-available">Available</span>`;
      if (isOutOfStock) {
        stockHtml = `<span class="product-stock stock-out">Out of Stock</span>`;
      } else if (isLowStock) {
        stockHtml = `<span class="product-stock stock-low">Only ${prod.total_stock} left</span>`;
      }

      const priceDisplay = prod.min_price === prod.max_price
        ? formatPrice(prod.min_price)
        : `${formatPrice(prod.min_price)} - ${formatPrice(prod.max_price)}`;

      const imageSrc = prod.image_url || PLACEHOLDER_IMG;

      return `
        <div class="product-card" onclick="openProductModal(${prod.id})">
          <div class="product-card-image">
            <img src="${imageSrc}" alt="${escapeHtml(prod.name)}" onerror="this.src='${PLACEHOLDER_IMG}'">
            <span class="category-badge">${escapeHtml(prod.category_name || 'General')}</span>
          </div>
          <div class="product-card-body">
            <h3>${escapeHtml(prod.name)}</h3>
            <p class="description">${escapeHtml(prod.description || '')}</p>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px;">
              <span class="product-price">${priceDisplay}</span>
              ${stockHtml}
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  async function openProductModal(productId) {
    try {
      const prod = await api(`/products/${productId}`);
      if (!prod) return;

      const sizeOptions = prod.variants.map((v, index) => {
        const outOfStockSuffix = v.stock_quantity === 0 ? ' (Out of stock)' : ` (${v.stock_quantity} left)`;
        return `<option value="${v.id}" data-price="${v.price}" data-stock="${v.stock_quantity}" ${index === 0 ? 'selected' : ''}>Size ${escapeHtml(v.size)}${outOfStockSuffix}</option>`;
      }).join('');

      const firstVariant = prod.variants[0] || { price: 0, stock_quantity: 0 };
      const initialPrice = formatPrice(firstVariant.price);

      const content = `
        <div style="position: relative;">
          <button style="position: absolute; right: -12px; top: -12px; background: none; border: none; font-size: 1.5rem; color: var(--text-muted); cursor: pointer;" onclick="closeModal()">×</button>
          <div style="display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 10px;">
            <div style="height: 200px; border-radius: var(--radius-md); overflow: hidden; background: var(--bg-secondary);">
              <img src="${prod.image_url || PLACEHOLDER_IMG}" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
            <div>
              <span class="badge badge-processing" style="margin-bottom: 8px;">${escapeHtml(prod.category_name || 'General')}</span>
              <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 8px;">${escapeHtml(prod.name)}</h2>
              <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 20px; max-height: 100px; overflow-y: auto;">${escapeHtml(prod.description || 'No description available.')}</p>
              
              <div class="form-group">
                <label for="modalSizeSelect">Choose Size</label>
                <select id="modalSizeSelect" class="form-control" onchange="handleModalVariantChange()">
                  ${sizeOptions}
                </select>
              </div>

              <div style="display: flex; gap: 16px; align-items: center; margin-top: 20px;">
                <div class="form-group" style="margin-bottom: 0; width: 100px;">
                  <label for="modalQuantity">Qty</label>
                  <input type="number" id="modalQuantity" class="form-control" value="1" min="1" oninput="handleQuantityValidation()">
                </div>
                <div style="flex: 1; text-align: right;">
                  <span style="font-size: 0.8rem; color: var(--text-muted); display: block;">Unit Price</span>
                  <span id="modalPriceDisplay" class="product-price" style="font-size: 1.6rem;">${initialPrice}</span>
                </div>
              </div>

              <div id="modalStockStatus" style="font-size: 0.85rem; margin-top: 12px; font-weight: 500;"></div>

              <div class="modal-actions" style="margin-top: 24px;">
                <button class="btn btn-secondary" onclick="closeModal()">Close</button>
                <button id="modalAddToCartBtn" class="btn btn-primary" onclick="addToCartSubmit(${prod.id})">Add to Cart</button>
              </div>
            </div>
          </div>
        </div>
      `;

      showModal(content);
      handleModalVariantChange();
    } catch (err) {
      showToast('Failed to load product details', 'error');
    }
  }

  function handleModalVariantChange() {
    const select = document.getElementById('modalSizeSelect');
    const selectedOption = select.options[select.selectedIndex];
    if (!selectedOption) return;

    const price = parseFloat(selectedOption.getAttribute('data-price'));
    const stock = parseInt(selectedOption.getAttribute('data-stock'));

    document.getElementById('modalPriceDisplay').textContent = formatPrice(price);
    
    const stockStatus = document.getElementById('modalStockStatus');
    const addToCartBtn = document.getElementById('modalAddToCartBtn');
    const qtyInput = document.getElementById('modalQuantity');

    if (stock === 0) {
      stockStatus.className = 'stock-out';
      stockStatus.textContent = 'Currently out of stock';
      addToCartBtn.disabled = true;
      qtyInput.disabled = true;
    } else if (stock <= 10) {
      stockStatus.className = 'stock-low';
      stockStatus.textContent = `Low Stock: Only ${stock} items remaining`;
      addToCartBtn.disabled = false;
      qtyInput.disabled = false;
      qtyInput.max = stock;
    } else {
      stockStatus.className = 'stock-available';
      stockStatus.textContent = 'In Stock';
      addToCartBtn.disabled = false;
      qtyInput.disabled = false;
      qtyInput.max = stock;
    }
    handleQuantityValidation();
  }

  function handleQuantityValidation() {
    const qtyInput = document.getElementById('modalQuantity');
    const select = document.getElementById('modalSizeSelect');
    const selectedOption = select.options[select.selectedIndex];
    if (!selectedOption) return;

    const stock = parseInt(selectedOption.getAttribute('data-stock'));
    let val = parseInt(qtyInput.value) || 1;

    if (val < 1) val = 1;
    if (val > stock) {
      val = stock;
      showToast(`Cannot select more than available stock (${stock})`, 'info');
    }
    qtyInput.value = val;
  }

  async function addToCartSubmit(productId) {
    if (!isLoggedIn()) {
      showToast('Authentication required. Please sign in to shop.', 'info');
      closeModal();
      setTimeout(() => { window.location.href = '/login'; }, 1000);
      return;
    }

    if (isStaff()) {
      showToast('Staff members cannot add products to cart.', 'error');
      return;
    }

    const select = document.getElementById('modalSizeSelect');
    const variantId = parseInt(select.value);
    const quantity = parseInt(document.getElementById('modalQuantity').value) || 1;

    try {
      await api('/cart', {
        method: 'POST',
        body: JSON.stringify({ variant_id: variantId, quantity })
      });

      showToast('Product added to your cart!', 'success');
      updateCartBadge();
      closeModal();
    } catch (err) {
      showToast(err.message || 'Failed to add to cart', 'error');
    }
  }
</script>
