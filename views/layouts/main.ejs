<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="OutpostClaude - Premium E-Commerce Platform">
  <title><%= typeof title !== 'undefined' ? title + ' | OutpostClaude' : 'OutpostClaude' %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-brand">
        <span class="logo-icon">⚡</span>
        OutpostClaude
      </a>

      <button class="nav-toggle" onclick="document.querySelector('.nav-links').classList.toggle('open')" aria-label="Toggle navigation">☰</button>

      <ul class="nav-links" id="navLinks">
        <li><a href="/" id="nav-catalog">🛍️ Catalog</a></li>
        <li class="nav-auth-hide" style="display:none;">
          <a href="/cart" id="nav-cart" class="nav-cart">
            🛒 Cart
            <span class="cart-badge" id="cartBadge">0</span>
          </a>
        </li>
        <li class="nav-auth-hide" style="display:none;">
          <a href="/orders" id="nav-orders">📦 Orders</a>
        </li>
        <li class="nav-auth-hide" style="display:none;">
          <a href="/profile" id="nav-profile">👤 Profile</a>
        </li>
        <!-- Staff links -->
        <li class="nav-staff-hide" style="display:none;">
          <a href="/staff" id="nav-staff-dashboard">📊 Dashboard</a>
        </li>
        <li class="nav-staff-hide" style="display:none;">
          <a href="/staff/orders" id="nav-staff-orders">📋 Manage Orders</a>
        </li>
        <li class="nav-staff-hide" style="display:none;">
          <a href="/staff/reports" id="nav-staff-reports">📈 Reports</a>
        </li>
      </ul>

      <div class="nav-user">
        <span class="user-name" id="navUserName" style="display:none;"></span>
        <a href="/login" class="btn btn-primary btn-sm" id="navLoginBtn">Sign In</a>
        <button class="btn btn-secondary btn-sm" id="navLogoutBtn" style="display:none;" onclick="handleLogout()">Logout</button>
      </div>
    </div>
  </nav>

  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- Modal Overlay -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modalContent"></div>
  </div>

  <!-- Page Content -->
  <main class="page-content">
    <div class="container">
      <%- body %>
    </div>
  </main>

  <!-- Core JS -->
  <script src="/js/api.js"></script>
  <script>
    // Initialize navbar state on load
    document.addEventListener('DOMContentLoaded', () => {
      updateNavbar();
      updateCartBadge();
    });
  </script>
</body>
</html>
