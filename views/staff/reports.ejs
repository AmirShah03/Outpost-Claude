<div class="staff-page-header">
  <div>
    <h1>Sales Reports</h1>
    <p>Generate and download monthly sales reports.</p>
  </div>
</div>

<!-- Generate Report -->
<div class="staff-panel" style="margin-bottom: 24px;">
  <div class="staff-panel-header">
    <h2><i class="fas fa-chart-bar" style="color: #F97316; margin-right: 8px;"></i> Generate New Report</h2>
  </div>
  <div style="padding: 20px; display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap;">
    <div class="filter-group">
      <label for="reportMonth">Month</label>
      <select id="reportMonth" class="form-control">
        <option value="1">January</option><option value="2">February</option><option value="3">March</option>
        <option value="4">April</option><option value="5">May</option><option value="6">June</option>
        <option value="7">July</option><option value="8">August</option><option value="9">September</option>
        <option value="10">October</option><option value="11">November</option><option value="12">December</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="reportYear">Year</label>
      <select id="reportYear" class="form-control"></select>
    </div>
    <button class="btn btn-primary" onclick="generateReport()"><i class="fas fa-magic"></i> Generate Report</button>
  </div>
</div>

<!-- Existing Reports -->
<div class="staff-panel" style="margin-bottom: 24px;">
  <div class="staff-panel-header">
    <h2><i class="fas fa-file-alt" style="color: #F97316; margin-right: 8px;"></i> Existing Reports</h2>
  </div>
  <div id="reportListContainer"><div class="spinner-sm"></div></div>
</div>

<!-- Report Detail -->
<div id="reportDetailSection" style="display: none;">
  <div class="staff-panel">
    <div class="staff-panel-header">
      <h2 id="reportDetailTitle">Report Detail</h2>
      <div style="display: flex; gap: 8px;">
        <a id="reportPdfLink" href="#" target="_blank" class="btn btn-outline"><i class="fas fa-download"></i> Download PDF</a>
        <button class="btn btn-danger-outline" onclick="deleteCurrentReport()"><i class="fas fa-trash"></i> Delete</button>
      </div>
    </div>
    <div id="reportDetailContent" style="padding: 20px;"></div>
  </div>
</div>

<script>
  if (!requireStaff()) {}
  let currentReportId = null;

  document.addEventListener('DOMContentLoaded', () => {
    // Populate year dropdown
    const yearSelect = document.getElementById('reportYear');
    const currentYear = new Date().getFullYear();
    for (let y = currentYear; y >= 2023; y--) {
      const opt = document.createElement('option');
      opt.value = y;
      opt.textContent = y;
      yearSelect.appendChild(opt);
    }
    // Set default month to current
    document.getElementById('reportMonth').value = new Date().getMonth() + 1;
    loadReportList();
  });

  async function loadReportList() {
    const container = document.getElementById('reportListContainer');
    try {
      const reports = await api('/reports');
      if (!reports || reports.length === 0) {
        container.innerHTML = `<div class="empty-state-sm"><i class="fas fa-inbox"></i><p>No reports generated yet.</p></div>`;
        return;
      }
      const months = ['','January','February','March','April','May','June','July','August','September','October','November','December'];
      container.innerHTML = `
        <table class="data-table">
          <thead>
            <tr><th>Report Title</th><th>Generated By</th><th>Date</th><th>Actions</th></tr>
          </thead>
          <tbody>
            ${reports.map(r => `
              <tr>
                <td><strong>${escapeHtml(r.title || `${months[r.month]} ${r.year} Report`)}</strong></td>
                <td>${escapeHtml(r.generated_by_name || '—')}</td>
                <td>${formatDate(r.created_at)}</td>
                <td>
                  <button class="btn btn-sm btn-outline" onclick="viewReport(${r.id})"><i class="fas fa-eye"></i> View</button>
                  <a href="/api/reports/${r.id}/pdf" target="_blank" class="btn btn-sm btn-outline"><i class="fas fa-file-pdf"></i> PDF</a>
                  <button class="btn btn-sm" style="background: #FEE2E2; color: #DC2626;" onclick="deleteReport(${r.id})"><i class="fas fa-trash"></i></button>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      `;
    } catch (err) {
      container.innerHTML = `<div class="empty-state-sm"><p style="color: var(--danger);">${escapeHtml(err.message)}</p></div>`;
    }
  }

  async function generateReport() {
    const month = parseInt(document.getElementById('reportMonth').value);
    const year = parseInt(document.getElementById('reportYear').value);
    try {
      await api('/reports/generate', {
        method: 'POST',
        body: JSON.stringify({ month, year })
      });
      showToast('Report generated successfully!', 'success');
      loadReportList();
    } catch (err) {
      showToast(err.message || 'Failed to generate report', 'error');
    }
  }

  async function viewReport(reportId) {
    currentReportId = reportId;
    try {
      const report = await api(`/reports/${reportId}`);
      const data = report.data || {};
      const orders = data.orders || [];
      const months = ['','January','February','March','April','May','June','July','August','September','October','November','December'];

      document.getElementById('reportDetailTitle').textContent =
        report.title || `${months[report.month]} ${report.year} Sales Report`;
      document.getElementById('reportPdfLink').href = `/api/reports/${reportId}/pdf`;

      if (orders.length === 0) {
        document.getElementById('reportDetailContent').innerHTML = `
          <div class="empty-state-sm"><i class="fas fa-inbox"></i><p>No records found for this period.</p></div>`;
      } else {
        document.getElementById('reportDetailContent').innerHTML = `
          <div style="display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 24px;">
            <div class="stat-card" style="flex: 1;">
              <div class="stat-value">${data.total_orders ?? 0}</div>
              <div class="stat-label">Total Orders</div>
            </div>
            <div class="stat-card" style="flex: 1;">
              <div class="stat-value">${formatPrice(data.total_revenue ?? 0)}</div>
              <div class="stat-label">Total Revenue</div>
            </div>
            <div class="stat-card" style="flex: 1;">
              <div class="stat-value">${data.card_payments ?? 0}</div>
              <div class="stat-label">Card Payments</div>
            </div>
            <div class="stat-card" style="flex: 1;">
              <div class="stat-value">${data.banking_payments ?? 0}</div>
              <div class="stat-label">Bank Transfers</div>
            </div>
          </div>
          <div style="overflow-x: auto;">
            <table class="data-table">
              <thead>
                <tr><th>Order ID</th><th>Customer</th><th>Payment Method</th><th>Status</th><th>Date</th><th style="text-align:right;">Amount</th></tr>
              </thead>
              <tbody>
                ${orders.map(o => `
                  <tr>
                    <td><strong>#${o.id}</strong></td>
                    <td>${escapeHtml(o.customer_name || '—')}</td>
                    <td>${o.payment_method === 'card' ? '💳 Card' : '🏦 Online Banking'}</td>
                    <td>${getStatusBadge(o.status)}</td>
                    <td>${formatDate(o.date)}</td>
                    <td style="text-align:right; font-weight: 700; color: #F97316;">${formatPrice(o.total)}</td>
                  </tr>
                `).join('')}
              </tbody>
              <tfoot>
                <tr style="background: #F8FAFC;">
                  <td colspan="5" style="font-weight: 700; padding: 12px 16px;">Total Revenue</td>
                  <td style="text-align:right; font-weight: 800; font-size: 1.1rem; color: #F97316; padding: 12px 16px;">${formatPrice(data.total_revenue)}</td>
                </tr>
              </tfoot>
            </table>
          </div>
        `;
      }

      document.getElementById('reportDetailSection').style.display = 'block';
      document.getElementById('reportDetailSection').scrollIntoView({ behavior: 'smooth' });
    } catch (err) {
      showToast(err.message || 'Failed to load report', 'error');
    }
  }

  async function deleteReport(reportId) {
    if (!confirm('Delete this report? This cannot be undone.')) return;
    try {
      await api(`/reports/${reportId}`, { method: 'DELETE' });
      showToast('Report deleted.', 'success');
      if (currentReportId === reportId) {
        document.getElementById('reportDetailSection').style.display = 'none';
        currentReportId = null;
      }
      loadReportList();
    } catch (err) {
      showToast(err.message || 'Failed to delete report', 'error');
    }
  }

  function deleteCurrentReport() {
    if (currentReportId) deleteReport(currentReportId);
  }
</script>
