# 1. Use a specific LTS version instead of 'latest' for stability
FROM ubuntu:24.04

# 2. Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# 3. Install core dev tools, fix the NodeSource key, and install Node.js
RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    gnupg \
    git \
    vim \
    build-essential \
    sudo \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" | tee /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 4. Verify installation versions & install your global package
RUN node -v && npm -v && npm i -g opencode-ai

# 5. Create a non-root user with an explicit HOME directory
# 5. Create a non-root user with an explicit HOME directory
ARG USERNAME=developer
ARG USER_UID=1000
ARG USER_GID=1000
ENV HOME=/home/$USERNAME

# Delete the default 'ubuntu' user if it exists, then create our developer user
RUN (userdel -r ubuntu || true) \
    && groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m -d $HOME -s /bin/bash $USERNAME \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# 6. Switch to the new non-root user
USER $USERNAME

# 7. Set the working directory
WORKDIR /app

RUN npm install && git config --global --add safe.directory /app && git config core.filemode false

# 8. Keep the container alive so you can attach to it
CMD ["sleep", "infinity"]